APP_NAME="Inventory Reservation Service"
APP_VERSION="0.1.0"
DEBUG=false

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/inventory_db
REDIS_URL=redis://HOST:6379/0

RESERVATION_TTL_SECONDS=900

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEK=REPLACE_WITH_GENERATED_FERNET_KEY

PROVIDER_REQUEST_TIMEOUT=5.0

OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=60
OUTBOX_POLL_INTERVAL_SECONDS=2.0
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BASE_BACKOFF_SECONDS=5.0

SWEEPER_BATCH_SIZE=50
SWEEPER_POLL_INTERVAL_SECONDS=10.0

CB_FAILURE_THRESHOLD=5
CB_WINDOW_SECONDS=60
CB_COOLDOWN_SECONDS=30
